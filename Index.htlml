<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Polish Nail Salon</title>
<link rel="stylesheet" href="styles.css">
</head>

<body>

<div class="container">

    <div class="header">
<img src="IMG_8892.png" alt="Nail Salon Poster">
        <h1>NAIL SALON</h1>
        <p>MAGARPATTA DC.</p>
        <p>CALL 8623090348</p>
        <p>@polishbypooja</p>
    </div>

    <div class="card">
        <img src="IMG_8892.png" alt="Nail Salon Poster">
        <div>
            <h2>NAIL SERVICES</h2>
            <p>Manicure <span>350</span></p>
            <p>Pedicure <span>700</span></p>
            <p>Gel Polish <span>599</span></p>
            <p>Gel Extension <span>1300+</span></p>
            <p>Nail Art <span>50</span></p>
        </div>
    </div>

    <div class="card">
<img src="IMG_8892.png" alt="Nail Salon Poster">
        <div>
            <h2>SKINCARE</h2>
            <p>Basic Facial <span>800</span></p>
            <p>Deep Clean <span>1200</span></p>
            <p>Anti-Aging <span>1100</span></p>
            <p>Detan <span>300</span></p>
            <p>Cleanup <span>400</span></p>
        </div>
    </div>

    <div class="card">
<img src="IMG_8892.png" alt="Nail Salon Poster">
        <div>
            <h2>WAXING</h2>
            <p>Hand <span>200</span></p>
            <p>UA <span>50</span></p>
            <p>Full Leg <span>800</span></p>
            <p>Rica Hands <span>600</span></p>
            <p>Rica Legs <span>1000</span></p>
        </div>
    </div>

    <div class="card">
<img src="IMG_8892.png" alt="Nail Salon Poster">
        <div>
            <h2>ADDITIONAL</h2>
            <p>Body Polishing <span>1500</span></p>
            <p>Eyelash <span>3000+</span></p>
            <p>Threading <span>50</span></p>
            <p>Massage <span>350</span></p>
            <p>Removal <span>300+</span></p>
        </div>
    </div>

    <div class="map-section">
        <iframe src="https://www.google.com/maps?q=Destination%20Center%20Magarpatta&output=embed"></iframe>
    </div>

    <p class="footer">By Appointments</p>

</div>

</body>
</html>